# ------------------------------------------------------------
# Redis (Upstash — get from upstash.com console)
# ------------------------------------------------------------
REDIS_URL="rediss://default:[password]@[endpoint].upstash.io:6379"

# ------------------------------------------------------------
# JWT (custom auth — NOT Supabase Auth)
# ------------------------------------------------------------
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"

# ------------------------------------------------------------
# App
# ------------------------------------------------------------
PORT=4000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# ------------------------------------------------------------
# Email (Resend — get from resend.com)
# ------------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="noreply@yourdomain.com"

# ------------------------------------------------------------
# Supabase Storage bucket names (must match buckets you created)
# ------------------------------------------------------------
STORAGE_BUCKET_POD="pod-files"
STORAGE_BUCKET_DOCUMENTS="fleet-documents"
STORAGE_BUCKET_LOGOS="agency-logos"
STORAGE_BUCKET_PDFS="invoice-pdfs"
STORAGE_BUCKET_DRIVER_DOCS="driver-documents"

# ------------------------------------------------------------
# Session timeouts (minutes)
# ------------------------------------------------------------
WEB_SESSION_TIMEOUT=30
MOBILE_SESSION_TIMEOUT=60

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
BCRYPT_ROUNDS=12
